logs/

# ─── 敏感内容（示例文件除外）──────────────────────────

# 灵魂文件 — 示例文件 (.example) 可提交
/soul/*
!/soul/*.example
packages/agent-soul-framework/soul/*.md

# 知识库 — 示例文件 (.example) 可提交
/knowledge/*
!/knowledge/INDEX.md.example
!/knowledge/*/INDEX.md.example
packages/agent-soul-framework/knowledge/*/*.md
packages/agent-soul-framework/knowledge/INDEX.md

# OpenCode 配置 — 示例文件可提交
.opencode/opencode.json
.opencode/config.json
!.opencode/opencode.json.example
!.opencode/config.json.example
!.opencode/prompt.md.example
.opencode/prompt.md
.claude/
