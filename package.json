{
  "name": "@neomei/agent-soul-monorepo",
  "version": "4.5.19",
  "private": true,
  "description": "魂器 — 基于 OpenCode 的 AI Agent 管理层框架（monorepo）",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "clean": "npm run clean --workspaces",
    "test": "npm run test --workspaces --if-present",
    "publish:packages": "npm publish --workspaces --access public",
    "prepublishOnly": "npm run build",
    "version:bump": "node scripts/version-bump.js"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "ai-agent",
    "opencode",
    "agent-framework",
    "memory",
    "knowledge",
    "heartbeat",
    "llm",
    "agent-orchestration",
    "self-improving"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/NeoMei/agent-soul-framework"
  },
  "author": "NeoMei",
  "license": "MIT"
}
