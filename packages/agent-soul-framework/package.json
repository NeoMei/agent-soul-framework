{
  "name": "@neomei/agent-soul-framework",
  "version": "4.5.13",
  "description": "魂器核心框架 — 基于 OpenCode 的 AI Agent 管理层框架。持久记忆 · 自主学习 · 多端部署 · 心跳自治（纯 TypeScript）",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "agent-soul-framework": "bin/hunqi",
    "agent-soul-heartbeat": "dist/heartbeat/runner.js",
    "agent-soul-knowledge": "bin/hunqi-knowledge"
  },
  "files": [
    "dist",
    "bin",
    "plugin",
    "scripts/*.sh",
    "scripts/*.js",
    "connectors",
    "docs",
    "soul/*.example",
    "knowledge/*.example",
    "knowledge/*/INDEX.md.example",
    "memory/MEMORY.md.example",
    "heartbeat/heartbeat_tasks.json",
    ".opencode/*.example",
    ".opencode/tools/read-plugin.js",
    "AGENTS.md.example",
    "TOOLS.md.example",
    ".env.example",
    "README.md",
    "SECURITY.md",
    "start.sh",
    "hunqi.sh",
    "install.sh",
    "uninstall.sh",
    "heartbeat_wrapper.sh",
    "test.sh",
    "verify.sh",
    "start-feishu-daemon.sh",
    ".opencode/tools/search-memory.mjs",
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "ai-agent",
    "opencode",
    "agent-framework",
    "memory",
    "knowledge",
    "heartbeat",
    "feishu",
    "llm",
    "agent-orchestration",
    "self-improving"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/NeoMei/agent-soul-framework"
  },
  "author": "NeoMei",
  "license": "MIT",
  "dependencies": {
    "@neomei/agent-soul": "^4.5.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  }
}







